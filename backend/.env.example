# Django Settings
SECRET_KEY=django-insecure-replace-this-in-production-value-12345
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Set USE_POSTGRES=True to run on PostgreSQL.
# Set USE_POSTGRES=False (or leave as False) to run on SQLite locally.
USE_POSTGRES=False

# PostgreSQL variables (only used if USE_POSTGRES=True)
DB_NAME=expense_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# Tesseract OCR Configuration
# If Tesseract is not in system PATH, set path here. Example on Windows:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=tesseract
